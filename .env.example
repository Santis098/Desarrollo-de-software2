# Copia este archivo a `.env` (que ya esta en .gitignore) y rellena los valores.
# docker-compose.yml lee estas variables automaticamente.

SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:6543/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.<project-ref>
SPRING_DATASOURCE_PASSWORD=<rotated-password>
